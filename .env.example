# AI Software Company Environment Variables
# Copy this file to .env and fill in your values

# Required: Anthropic API Key for PO, TL, QA agents
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional: Maximum parallel developers (default: unlimited)
# MAX_DEVS=3

# Optional: Maximum QA cycles before blocking task (default: 2)
# MAX_QA_CYCLES=2

# Optional: Maximum Review cycles before blocking task (default: 2)
# MAX_REVIEW_CYCLES=2
